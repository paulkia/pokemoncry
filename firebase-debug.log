[debug] [2025-12-17T06:28:50.685Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/guessthecry/rulesets {"name":"projects/guessthecry/rulesets/de23cbe8-57e4-42a3-bedb-dcf797aeb2c4","source":{"files":[{"content":"// For the most part, we want to reject all reads and writes.\n// Clients should do these via server functions.\n\nrules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    // Allow users to view best global runs.\n    match /runs/{runId} {\n      allow read: if true;\n      allow write: if false;\n    }\n\n    // Session use-case: user should be able to read the next cry,\n    // written by a cloud task.\n    match /protected-session-data/{sessionId} {\n      // ALLOW READ IF:\n      // 1. User is logged in (request.auth != null)\n      // 2. The 'uid' field on the PARENT document matches their UID\n      allow read: if request.auth != null && \n                  get(/databases/$(database)/documents/protected-session-data/$(sessionId)).data.uid == request.auth.uid;\n      allow write: if false;\n    }\n\n    match /users/{uid} {\n      allow read: if uid == request.auth.uid;\n      allow write: if uid == request.auth.uid;\n    }\n  }\n}","name":"firestore.rules"}]},"createTime":"2025-12-17T06:28:50.650687Z","metadata":{"services":["cloud.firestore"]}}
