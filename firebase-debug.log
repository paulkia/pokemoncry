[debug] [2025-12-17T08:14:59.417Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/guessthecry/rulesets {"name":"projects/guessthecry/rulesets/0046809b-c725-4067-8eec-2ab37c10be40","source":{"files":[{"content":"// For the most part, we want to reject all reads and writes.\n// Clients should do these via server functions.\n\nrules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    // Allow users to view best global runs.\n    match /public-runs/{runId} {\n      allow read: if true;\n      allow write: if false;\n    }\n\n    // Session use-case: user should be able to read the next cry,\n    // written by a cloud task.\n    match /protected-sessions/{sessionId} {\n      // ALLOW READ IF:\n      // 1. User is logged in (request.auth != null)\n      // 2. The 'uid' field on the PARENT document matches their UID\n      allow read: if request.auth != null &&\n        exists(/databases/$(database)/documents/sessions/$(sessionId)) &&\n        get(/databases/$(database)/documents/sessions/$(sessionId)).data.uid == request.auth.uid;\n      allow write: if false;\n    }\n\n    match /protected-users/{uid} {\n      allow read: if uid == request.auth.uid;\n      allow write: if uid == request.auth.uid;\n    }\n  }\n}","name":"firestore.rules"}]},"createTime":"2025-12-17T08:14:59.385807Z","metadata":{"services":["cloud.firestore"]}}
[debug] [2025-12-17T08:14:59.417Z] [rules] created ruleset projects/guessthecry/rulesets/0046809b-c725-4067-8eec-2ab37c10be40
